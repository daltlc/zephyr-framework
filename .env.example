# Shared .env for all Zephyr tools (MCP server, Electron browser, etc.)

# AI provider key — used by zephyr-browser and <z-agent> proxy endpoints
ANTHROPIC_API_KEY=

# zephyr-mcp server configuration (all optional)
ZEPHYR_MCP_PORT=3456        # MCP server port (default: 3456)
ZEPHYR_ROOT=                # Override path to zephyr-framework root directory

# zephyr-browser configuration (all optional)
ZEPHYR_MODEL=claude-haiku-4-20250506  # Model for the agent loop

# Note: The <z-agent> widget uses HTML attributes (data-api-key, data-endpoint,
# data-provider) rather than env vars. See README.md for usage.
