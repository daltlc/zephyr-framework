{
  "name": "zephyr-framework",
  "version": "0.3.1",
  "description": "The first UI framework built for AI agents. 14 web components with pure CSS interactions, zero runtime JavaScript. Built-in MCP server, A2UI catalog, and structured Agent API.",
  "main": "zephyr-framework.js",
  "module": "zephyr-framework.js",
  "types": "zephyr-framework.d.ts",
  "sideEffects": true,
  "scripts": {
    "build": "node build.js",
    "test": "echo \"Open tests/index.html in a browser to run the test suite\"",
    "dev": "npx http-server -c-1"
  },
  "files": [
    "zephyr-framework.js",
    "zephyr-framework.min.js",
    "zephyr-framework.css",
    "zephyr-framework.min.css",
    "zephyr-framework.d.ts",
    "zephyr-agent-widget.js",
    "zephyr-agent-widget.min.js",
    "zephyr-schema.json",
    "zephyr-prompt.md",
    "zephyr-a2ui-catalog.json",
    "dashboard/zephyr-dashboard.js",
    "dashboard/zephyr-dashboard.min.js",
    "dashboard/zephyr-dashboard.css",
    "dashboard/zephyr-dashboard.min.css",
    "LICENSE"
  ],
  "keywords": [
    "web-components",
    "css",
    "ui-framework",
    "ai-agent",
    "mcp",
    "a2ui",
    "zero-js",
    "custom-elements",
    "model-context-protocol",
    "llm",
    "dashboard",
    "charts"
  ],
  "author": "Dalton Carr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daltlc/zephyr-framework.git"
  },
  "homepage": "https://daltlc.github.io/zephyr-framework/",
  "bugs": {
    "url": "https://github.com/daltlc/zephyr-framework/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
